{
  "manifest_version": 3,
  "name": "Archive.org Book OCR & Translator",
  "version": "1.1.0",
  "description": "Capture the current page of an Internet Archive book reader, OCR it with Gemini, and view the translation, original text, and commentary in a resizable sidebar that pushes the page content aside.",
  "permissions": [
    "activeTab",
    "storage",
    "scripting"
  ],
  "host_permissions": [
    "<all_urls>",  
    "https://archive.org/*",
    "https://*.archive.org/*",
    "https://generativelanguage.googleapis.com/*"
  ],
  "action": {
    "default_title": "OCR & Translate this page"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://archive.org/details/*",
        "https://*.archive.org/details/*"
      ],
      "js": ["content.js"],
      "css": ["sidebar.css"],
      "run_at": "document_idle"
    }
  ],
  "options_page": "options.html",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
